# Required for the default demo
OPENAI_API_KEY=sk-...

# Optional — override the default model
# OPENAI_MODEL=gpt-4o

# Optional — swap in Claude
# ANTHROPIC_API_KEY=sk-ant-...

# Optional — point at a live MCP server. If unset, the agent uses the
# in-process rules fixture in agent/tools.py so the demo runs offline.
# MCP_SERVER_URL=http://localhost:8000/sse
